{
  "info": {
    "name": "Supabase Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL",     "value": "http://localhost:3000" },
    { "key": "ACCESS_TOKEN", "value": "" },
    { "key": "POST_ID",      "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "OTP - Invia SMS",
          "request": { "method": "POST", "url": "{{BASE_URL}}/auth/otp/send",
                       "header": [{ "key": "Content-Type", "value": "application/json" }],
                       "body": { "mode": "raw", "raw": "{ \"phone\": \"+393331234567\" }" } },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Messaggio presente', () => pm.expect(pm.response.json()).to.have.property('message'));"
          ]}}]
        },
        {
          "name": "OTP - Verifica codice",
          "request": { "method": "POST", "url": "{{BASE_URL}}/auth/otp/verify",
                       "header": [{ "key": "Content-Type", "value": "application/json" }],
                       "body": { "mode": "raw", "raw": "{ \"phone\": \"+393331234567\", \"token\": \"123456\" }" } },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "if (j.access_token) pm.collectionVariables.set('ACCESS_TOKEN', j.access_token);",
            "pm.test('access_token presente', () => pm.expect(j).to.have.property('access_token'));"
          ]}}]
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "GET Lista post",
          "request": { "method": "GET", "url": { "raw": "{{BASE_URL}}/posts?page=1&limit=10",
                       "query": [{"key":"page","value":"1"},{"key":"limit","value":"10"}] } },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "pm.test('Paginazione', () => { pm.expect(j).to.have.property('data'); pm.expect(j).to.have.property('pagination'); });"
          ]}}]
        },
        {
          "name": "POST Crea post (auth)",
          "request": { "method": "POST", "url": "{{BASE_URL}}/posts",
                       "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{ACCESS_TOKEN}}"}],
                       "body": { "mode": "raw", "raw": "{ \"title\": \"Test post Postman\", \"content\": \"Contenuto test\" }" } },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const j = pm.response.json(); pm.collectionVariables.set('POST_ID', j.id);",
            "pm.test('ID presente', () => pm.expect(j).to.have.property('id'));"
          ]}}]
        },
        {
          "name": "POST Crea post — no auth (401)",
          "request": { "method": "POST", "url": "{{BASE_URL}}/posts",
                       "header": [{"key":"Content-Type","value":"application/json"}],
                       "body": { "mode": "raw", "raw": "{ \"title\": \"Test\", \"content\": \"Test\" }" } },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));"
          ]}}]
        },
        {
          "name": "POST Crea post — titolo corto (422)",
          "request": { "method": "POST", "url": "{{BASE_URL}}/posts",
                       "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{ACCESS_TOKEN}}"}],
                       "body": { "mode": "raw", "raw": "{ \"title\": \"AB\", \"content\": \"Test\" }" } },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 422', () => pm.response.to.have.status(422));",
            "pm.test('Errori validazione', () => pm.expect(pm.response.json()).to.have.property('errors'));"
          ]}}]
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "POST Checkout session",
          "request": { "method": "POST", "url": "{{BASE_URL}}/payments/checkout",
                       "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{ACCESS_TOKEN}}"}],
                       "body": { "mode": "raw", "raw": "{ \"priceId\": \"price_xxx\", \"mode\": \"payment\" }" } },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('URL presente', () => pm.expect(pm.response.json()).to.have.property('url'));"
          ]}}]
        },
        {
          "name": "GET Abbonamento attivo",
          "request": { "method": "GET", "url": "{{BASE_URL}}/payments/subscription",
                       "header": [{"key":"Authorization","value":"Bearer {{ACCESS_TOKEN}}"}] },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('subscription presente', () => pm.expect(pm.response.json()).to.have.property('subscription'));"
          ]}}]
        }
      ]
    }
  ]
}
